{
  "name": "ts-koa-template",
  "version": "0.0.1",
  "author": "Danil Gusev aka 51Sirius",
  "license": "MIT",
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "files": [
    "/dist"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "start:ts": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/app.ts",
    "test": "dotenv -e .env jest",
    "test:watch": "dotenv -e .env jest --watch",
    "test:cov": "dotenv -e .env jest --coverage",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"{src,tests}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "docker": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@koa/router": "^15.0.0",
    "dotenv": "17.2.0",
    "koa": "^3.1.1",
    "koa-bodyparser": "^4.4.1",
    "koa-json": "2.0.2",
    "koa-router": "^13.1.1",
    "pg": "^8.16.3",
    "rimraf": "6.0.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/koa": "^3.0.1",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-json": "2.0.23",
    "@types/koa-router": "^7.4.8",
    "@types/koa__router": "12.0.4",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "30.0.0",
    "nock": "14.0.5",
    "prettier": "3.6.2",
    "ts-jest": "29.4.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
